{
  "name": "@ctg-exchange/sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for the CTG.EXCHANGE exchange API (REST + WebSocket)",
  "license": "Apache-2.0",
  "author": "CTG.EXCHANGE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ctg-exchange",
    "crypto",
    "exchange",
    "trading",
    "api",
    "sdk",
    "websocket"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cryptorg-io/ctg-exchange-typescript.git"
  },
  "homepage": "https://docs.ctg.exchange"
}
