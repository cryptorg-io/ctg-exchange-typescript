# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Credentials are read by the integration tests (see test/integration.test.ts).
CTG_EXCHANGE_API_KEY=ak_your_key_id_here
CTG_EXCHANGE_API_SECRET=sk_your_secret_here
# Optional REST base URL override:
# CTG_EXCHANGE_BASE_URL=https://api.ctg.exchange
